{
    "$schema": "./config_schema.json",
    "userIDField": "https://mydittoapp.com/name",
    "defaultExpirationSeconds": 3600,
    "JWTSecret": "a-string-secret-at-least-256-bits-long",
    "clientInfo": {
        "info": "This is some client info"
    },
    "identityServiceMetadata": {
        "metadata": "This is some identity service metadata"
    },
    "roles": {
        "admin": {
            "members": [
                "Account 1"
            ],
            "permissions": {
                "read": "*",
                "write": "*"
            }
        },
        "normal_user": {
            "members": [
                "Account 2"
            ],
            "permissions": {
                "read": "*",
                "write": {}
            }
        },
        "guest": {
            "members": [
                "Account 3"
            ],
            "permissions": {
                "read": {
                    "tasks": [" _id == '688ce8e000062161004e3cfa'"]
                },
                "write": {
                    "tasks": [" _id == '688ce8e000062161004e3cfa'"]
                }
            }
        }
    }
}